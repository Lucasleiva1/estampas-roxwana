{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos principales de ROXWANA Biblioteca Visual",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$APPCACHE/**/*" },
        { "path": "$APPLOCALDATA/**/*" }
      ]
    },
    "opener:default",
    "opener:allow-open-path",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "sql:default"
  ]
}
