{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ROXWANA Biblioteca Visual",
  "version": "0.1.5",
  "identifier": "com.roxwana.biblioteca-visual",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ROXWANA - Biblioteca Visual",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**/*", "$APPCACHE/**/*", "$APPLOCALDATA/**/*"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0QTZFQjcyMDk1NTU2MEMKUldRTVZsVUpjdXVtNUJNR2FLN0JOcVhQb2ZobmJoY2F5M3U3c2l2ZUpCSi9Dc3hqYWoxMTNMSXQK",
      "endpoints": [
        "https://github.com/Lucasleiva1/estampas-roxwana/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
